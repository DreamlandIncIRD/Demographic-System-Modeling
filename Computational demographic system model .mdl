{UTF-8}
Birth cur=
	DELAY FIXED(Burth prev+Birth Rate*Adult cur*TIME STEP,TIME STEP,0)
	~	
	~		|

Burth prev=
	DELAY FIXED(Birth cur, TIME STEP, 0)
	~	
	~		|

Adult cur=
	DELAY FIXED(Adult prev+(Mature-Aging-Death Adult), TIME STEP
	, Adult Init)
	~	
	~		|

Adult Init=
	1000
	~	
	~		|

Adult prev=
	DELAY FIXED(Adult cur, TIME STEP, Adult Init)
	~	
	~		|

Aging=
	Adult cur*TIME STEP/Aging Time
	~	
	~		|

Aging Time=
	40
	~	
	~		|

Birth=
	Birth Rate*Adult cur*TIME STEP
	~	
	~		|

Birth Rate=
	0.035
	~	
	~		|

Death Adult=
	Adult cur*Death Rate Adult*TIME STEP
	~	
	~		|

Young cur=
	DELAY FIXED(Young prev+(Birth-Mature), TIME STEP, Young Init)
	~	
	~		|

Young Init=
	300
	~	
	~		|

Young prev=
	DELAY FIXED(Young cur, TIME STEP, Young Init)
	~	
	~		|

Death Rate Adult=
	0.01
	~	
	~		|

Old prev=
	DELAY FIXED(Old cur, TIME STEP, Old Init)
	~	
	~		|

Mature=
	Young cur*TIME STEP/Mature Time
	~	
	~		|

Mature Time=
	20
	~	
	~		|

Old cur=
	DELAY FIXED(Old prev+(Aging-Death Old), TIME STEP, Old Init)
	~	
	~		|

Old Init=
	50
	~	
	~		|

Death Old=
	Old cur*Death Rate Old*TIME STEP
	~	
	~		|

Death prev=
	DELAY FIXED(Death cur, TIME STEP, 0)
	~	
	~		|

Death cur=
	DELAY FIXED(Death prev+Death Old+Death Adult, TIME STEP, 0)
	~	
	~		|

Death Rate Old=
	0.01
	~	
	~		|

********************************************************
	.Control
********************************************************~
		Simulation Control Parameters
	|

FINAL TIME  = 100
	~	Year
	~	The final time for the simulation.
	|

INITIAL TIME  = 0
	~	Year
	~	The initial time for the simulation.
	|

SAVEPER  = 
        TIME STEP 
	~	Year [0,?]
	~	The frequency with which output is stored.
	|

TIME STEP  = 0.25
	~	Year [0,?]
	~	The time step for the simulation.
	|

